# =============================================================================
# GroupeMicroservices — Configuration d'environnement
# =============================================================================
# Copier ce fichier en `.env` à la racine du projet :
#   cp .env.example .env
#
# Le fichier `.env` est lu automatiquement par `docker compose` et NE DOIT PAS
# être commité (déjà dans .gitignore).
# =============================================================================


# -----------------------------------------------------------------------------
# PROFIL SPRING
# -----------------------------------------------------------------------------
# `prod` pour le docker-compose (utilise application-prod.yml de chaque service)
# `default` ou `dev` pour le développement local
SPRING_PROFILES_ACTIVE=prod


# -----------------------------------------------------------------------------
# POSTGRESQL (avec extension PostGIS)
# -----------------------------------------------------------------------------
# Identifiants admin Postgres (utilisateur créé au premier démarrage)
POSTGRES_USER=inno2711
POSTGRES_PASSWORD=manager2711
POSTGRES_DB=innodb

# Alias utilisés par les microservices Spring pour s'authentifier
# (égaux à POSTGRES_USER/POSTGRES_PASSWORD par défaut)
DB_USERNAME=inno2711
DB_PASSWORD=manager2711

# Port du host (côté machine) — port interne du conteneur reste 5433.
# Mettre 5435 si un autre Postgres tourne déjà sur 5433 (dev local).
# Mettre 5433 sur les serveurs de prod où aucun conflit.
POSTGRES_HOST_PORT=5435


# -----------------------------------------------------------------------------
# PGADMIN (outil web optionnel, profile `tools` uniquement)
# -----------------------------------------------------------------------------
PGADMIN_EMAIL=admin@guidipress-io.com
PGADMIN_PASSWORD=changez-moi


# -----------------------------------------------------------------------------
# EUREKA (service discovery)
# -----------------------------------------------------------------------------
EUREKA_USER=manager
EUREKA_PASSWORD=manager2711


# -----------------------------------------------------------------------------
# FRONTEND / URLs publiques
# -----------------------------------------------------------------------------
# URL publique de l'app Angular (utilisée pour redirects OAuth2 et CORS)
UI_APP_URL=http://localhost:4202

# Issuer OAuth2 publique (URL du authorizationserver vu depuis l'extérieur)
OAUTH_ISSUER=http://localhost:8090

# `true` en prod (HTTPS), `false` en dev (HTTP)
SESSION_COOKIE_SECURE=false


# -----------------------------------------------------------------------------
# GOOGLE OAUTH2 (login Google)
# -----------------------------------------------------------------------------
# Obtenir sur https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret


# -----------------------------------------------------------------------------
# GMAIL SMTP (envoi d'emails par notificationserver)
# -----------------------------------------------------------------------------
# Utiliser un mot de passe d'application Gmail :
# https://myaccount.google.com/apppasswords (compte avec 2FA activé)
GMAIL_USERNAME=votre-email@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
MAIL_FROM_NAME=Guidipress


# -----------------------------------------------------------------------------
# ORANGE SMS API (envoi de SMS en Guinée)
# -----------------------------------------------------------------------------
# Obtenir sur https://developer.orange.com
# Format : "Basic <base64(client_id:client_secret)>"
ORANGE_API_CREDENTIALS=Basic VExqQ1BlQ1ZDdUxTRURLUjc2Z0RZcXo5QWw4a3h5M3A6...
ORANGE_SENDER_ADDRESS=tel:+224622459305


# -----------------------------------------------------------------------------
# MINIO (stockage S3-compatible pour photos immobilières)
# -----------------------------------------------------------------------------
# Identifiants racine MinIO (admin sur la console web :9101)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changez-moi-en-prod

# URL publique servant les photos (utilisée par les clients pour générer les liens).
# Dev : http://localhost:9100
# Prod : https://photos.guidipress-io.com (via reverse-proxy nginx)
MINIO_PUBLIC_URL=http://localhost:9100
